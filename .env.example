# Copiez ce fichier en ".env" et remplissez vos vraies valeurs.
# Ne committez JAMAIS le fichier ".env" final sur GitHub.

# --- WhatsApp Cloud API (Meta Business Manager) ---
WHATSAPP_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=123456789012345
GRAPH_API_VERSION=v20.0

# Choisissez-le vous-même : une chaîne aléatoire que vous collez aussi
# dans la configuration du webhook côté Meta (Business Manager > WhatsApp > Configuration)
WEBHOOK_VERIFY_TOKEN=changez-moi-en-chaine-aleatoire

# --- Claude API ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-5

# --- Serveur ---
PORT=3000
# L'URL publique HTTPS de votre VPS (celle configurée dans Nginx + certbot),
# utilisée pour construire le lien des vidéos envoyées à WhatsApp.
PUBLIC_BASE_URL=https://wisheez.votredomaine.com
